# -- Blockchain --
LTAI_PAYMENT_PROCESSOR_CONTRACT_BASE=0x48E5A3e497D0C092D5B0Ba22B5A86ADA94227DFa
LTAI_PAYMENT_PROCESSOR_CONTRACT_SOLANA=21tHgbgC8Q6hoXyHx5pp3Gtp97B3HxrS2yH832ryeNSw
BASE_RPC_URL=https://mainnet.base.org
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# -- Database --
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
DATABASE_URL=postgresql://$POSTGRES_USER:$POSTGRES_PASSWORD@$POSTGRES_HOST/$POSTGRES_DB

THIRDWEB_WEBHOOK_SECRET=
THIRDWEB_SECRET_KEY=
THIRDWEB_VAULT_ACCESS_TOKEN=

# -- Logging --
LOG_LEVEL=INFO
LOG_FILE=

# -- Authentication --
JWT_SECRET=  # Generate a secure random key using: python -c "import secrets; print(secrets.token_hex(32))"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES="1440" # 1 day

ADMIN_SECRET=  # Generate a secure random key using: python -c "import secrets; print(secrets.token_hex(32))"

IS_DEVELOPMENT=False

VOUCHERS_PASSWORDS='["password1", "password2"]'

# -- Aleph --
# Use the testnet in development
#ALEPH_API_URL=https://api.twentysix.testnet.network
# Owner of the messages on Aleph (has given permissions to the sender)
ALEPH_OWNER=0x
# Sender of the messages on Aleph
ALEPH_SENDER=0x
# Private key of the address to send messages with
ALEPH_SENDER_SK=
# Public key of the address to send messages with
ALEPH_SENDER_PK=

# -- Agents --
# Channel on which to send agent messages
ALEPH_AGENT_CHANNEL=libertai-agents

# -- Chat --
# API key to use for free chat requests
LIBERTAI_CHAT_API_KEY=
# Base URL for the LibertAI Chat API
LIBERTAI_CHAT_API_BASE_URL=https://api.libertai.io

LIBERCLAW_SECRET=

# -- OAuth (register apps under the LibertAI GitHub org + a LibertAI Google Cloud project) --
# Google: console.cloud.google.com -> OAuth client; consent screen branded "LibertAI", domain-verified.
# Authorized redirect URI: $API_URL/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub: github.com/organizations/Libertai/settings/applications -> OAuth App.
# Authorization callback URL: $API_URL/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -- Magic-link / email (Resend; sender domain libertai.io, e.g. noreply@libertai.io) --
MAGIC_LINK_SECRET=  # python -c "import secrets; print(secrets.token_hex(32))"
RESEND_API_KEY=

# -- Token encryption (Fernet; used for one-time auth-code token storage) --
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# Set to the OLD key during a key rotation, otherwise leave empty
ENCRYPTION_KEY_PREVIOUS=

# -- URLs + token lifetimes --
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:8000
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# -- Payments (Revolut Merchant API) --
REVOLUT_SECRET_KEY=
REVOLUT_WEBHOOK_SECRET=
REVOLUT_API_URL=https://merchant.revolut.com
REVOLUT_API_VERSION=2024-09-01